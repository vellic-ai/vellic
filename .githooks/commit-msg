#!/usr/bin/env bash
# Reject commit messages that fingerprint AI-assisted authoring.
# Run: configured via `make hooks` (sets core.hooksPath to .githooks).
set -eu

msg_file="$1"
msg="$(cat "$msg_file")"

# Skip merge / fixup / squash / revert auto-messages
case "$(printf '%s' "$msg" | head -n1)" in
  Merge\ *|fixup!*|squash!*|"Revert \""*) exit 0 ;;
esac

violations=()

# Co-author trailers naming AI tools or bots
if printf '%s\n' "$msg" | grep -E -i -q '^[[:space:]]*Co-Authored-By:.*(claude|paperclip|anthropic|openai|copilot|chatgpt|gpt-?[0-9]|noreply@(paperclip|anthropic)\.)'; then
  violations+=("AI co-author trailer")
fi

# "Generated with <tool>" / "Generated by <tool>" footers
if printf '%s\n' "$msg" | grep -E -i -q 'generated (with|by) (claude|paperclip|anthropic|openai|copilot|chatgpt|cursor|an? ai)'; then
  violations+=("\"Generated with <AI tool>\" footer")
fi

# Robot emoji is the conventional AI-fingerprint marker
if printf '%s\n' "$msg" | grep -F -q $'\xf0\x9f\xa4\x96'; then
  violations+=("robot emoji")
fi

if [ ${#violations[@]} -gt 0 ]; then
  printf '\n[commit-msg] rejected — message contains AI-fingerprint content:\n' >&2
  for v in "${violations[@]}"; do printf '  - %s\n' "$v" >&2; done
  printf '\nWrite the message in the board member'\''s human voice.\n' >&2
  printf 'See /paperclip/projects/vellic-engineering-rules.md (Identity, Commit messages).\n\n' >&2
  exit 1
fi

exit 0
