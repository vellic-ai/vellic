# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real secrets.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=vellic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vellic

# ── GitHub webhook ────────────────────────────────────────────────────────────
# A random secret shared between GitHub and the api service for HMAC validation.
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=changeme

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key used to encrypt secrets at rest (LLM API keys, VCS tokens, webhook HMACs).
# Required. Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
LLM_ENCRYPTION_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
# Model pulled on first start. nomic-embed-text is small (~270 MB) and useful
# for local embeddings. Swap for llama3.2 or similar for generation tasks.
OLLAMA_MODEL=nomic-embed-text
