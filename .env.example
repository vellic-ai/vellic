# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real secrets.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=vellic
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vellic

# ── Optional: encryption key override ─────────────────────────────────────────
# By default Vellic generates a Fernet key on first boot and persists it to the
# shared `vellic_secrets` Docker volume (/data/secrets/llm_encryption_key).
# Set this only if you want to supply the key from your own secret manager.
#
# Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# LLM_ENCRYPTION_KEY=
